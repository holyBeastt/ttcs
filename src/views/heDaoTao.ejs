<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Học Viện Kỹ Thuật Mật Mã</title>
    <link rel="stylesheet" href="/css/table.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.all.min.js"></script>
    <style>
        body.he-dao-tao-page {
            background:
                radial-gradient(circle at top left, rgba(33, 150, 243, 0.12), transparent 28%),
                radial-gradient(circle at top right, rgba(255, 152, 0, 0.14), transparent 24%),
                linear-gradient(180deg, #f6f9fc 0%, #eef3f8 100%);
            min-height: 100vh;
        }

        .he-dao-tao-shell {
            max-width: 1320px;
        }

        .he-dao-tao-grid {
            display: grid;
            grid-template-columns: minmax(320px, 380px) minmax(0, 1fr);
            gap: 24px;
            align-items: start;
        }

        .he-dao-tao-card {
            background: rgba(255, 255, 255, 0.96);
            border: 1px solid rgba(18, 52, 88, 0.08);
            border-radius: 22px;
            box-shadow: 0 18px 45px rgba(15, 39, 68, 0.08);
            overflow: hidden;
        }

        .he-dao-tao-card__header {
            padding: 24px 24px 12px;
        }

        .he-dao-tao-card__body {
            padding: 0 24px 24px;
        }

        .page-kicker {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 12px;
            border-radius: 999px;
            background: #e8f1ff;
            color: #1554b3;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }

        .page-title {
            margin: 14px 0 8px;
            font-size: 28px;
            font-weight: 700;
            color: #16324f;
        }

        .page-subtitle {
            margin: 0;
            color: #62748a;
            line-height: 1.6;
        }

        .he-dao-tao-form {
            display: grid;
            gap: 18px;
        }

        .he-dao-tao-form label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: #26415f;
        }

        .he-dao-tao-form .form-control,
        .he-dao-tao-form .form-select {
            height: 48px;
            border-radius: 14px;
            border: 1px solid #dbe5f0;
            background: #f9fbfd !important;
            box-shadow: none;
            padding-left: 14px;
        }

        .he-dao-tao-form .form-control:focus,
        .he-dao-tao-form .form-select:focus,
        .toolbar-search:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 4px rgba(52, 152, 219, 0.12);
        }

        .submit-btn {
            height: 50px;
            border: none;
            border-radius: 14px;
            background: linear-gradient(135deg, #0d6efd 0%, #198754 100%);
            color: #fff;
            font-weight: 700;
            box-shadow: 0 14px 28px rgba(13, 110, 253, 0.22);
        }

        .toolbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            margin-bottom: 18px;
            flex-wrap: wrap;
        }

        .toolbar-title {
            min-width: 0;
        }

        .toolbar-title h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            color: #16324f;
        }

        .toolbar-title p {
            margin: 6px 0 0;
            color: #6b7b8d;
        }

        .toolbar-search-wrap {
            flex: 0 0 320px;
            max-width: 320px;
            width: 320px;
        }

        .toolbar-search {
            width: 100%;
            height: 46px;
            border-radius: 14px;
            border: 1px solid #dbe5f0;
            background: #f9fbfd;
            padding: 0 14px;
        }

        .table-shell {
            border: 1px solid #e5edf5;
            border-radius: 18px;
            overflow: hidden;
            background: #fff;
        }

        #heDaoTaoTable {
            margin-bottom: 0;
            border: none;
            box-shadow: none;
        }

        #heDaoTaoTable thead th {
            background: linear-gradient(135deg, #1a73e8 0%, #1459b8 100%) !important;
            border: none;
            padding: 14px 12px;
            font-size: 14px;
            white-space: nowrap;
        }

        #heDaoTaoTable tbody td {
            padding: 14px 12px;
            vertical-align: middle;
            border-color: #edf2f7;
        }

        .id-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 42px;
            height: 32px;
            padding: 0 10px;
            border-radius: 999px;
            background: #edf4ff;
            color: #1459b8;
            font-weight: 700;
        }

        .type-badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
        }

        .type-badge--moi-giang {
            background: #eaf8ef;
            color: #16794d;
        }

        .type-badge--do-an {
            background: #fff1e8;
            color: #c7681a;
        }

        .level-chip {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 36px;
            height: 32px;
            border-radius: 10px;
            background: #f1f5f9;
            color: #334155;
            font-weight: 700;
        }

        .empty-state {
            padding: 28px 12px !important;
            color: #738396;
        }

        @media (max-width: 991px) {
            .he-dao-tao-grid {
                grid-template-columns: 1fr;
            }

            .toolbar-search-wrap {
                flex: 1 1 100%;
                width: 100%;
                max-width: none;
            }
        }
    </style>
</head>

<body class="he-dao-tao-page">
    <%- include('adminHeader') %>

    <div class="container my-5 he-dao-tao-shell">
        <div class="he-dao-tao-grid">
            <section class="he-dao-tao-card">
                <div class="he-dao-tao-card__header">
                    <span class="page-kicker">
                        <i class="bi bi-building-add"></i>
                        Quản trị dữ liệu
                    </span>
                    <h1 class="page-title">Thêm Hệ Đào Tạo</h1>
                    <p class="page-subtitle">
                        Tạo nhanh hệ đào tạo mới với tên hệ, cấp độ và loại hình tương ứng.
                    </p>
                </div>

                <div class="he-dao-tao-card__body">
                    <form action="/heDaoTao" method="POST" class="he-dao-tao-form">
                        <div>
                            <label for="he_dao_tao">Tên hệ đào tạo</label>
                            <input
                                type="text"
                                class="form-control"
                                id="he_dao_tao"
                                name="he_dao_tao"
                                placeholder="Ví dụ: ĐH Mật mã Việt Nam"
                                required
                            />
                        </div>

                        <div>
                            <label for="cap_do">Cấp độ</label>
                            <select class="form-select" id="cap_do" name="cap_do" required>
                                <option value="">Chọn cấp độ</option>
                                <option value="1">Cấp độ 1</option>
                                <option value="2">Cấp độ 2</option>
                                <option value="3">Cấp độ 3</option>
                                <option value="4">Cấp độ 4</option>
                            </select>
                        </div>

                        <div>
                            <label for="loai_hinh">Loại hình</label>
                            <select class="form-select" id="loai_hinh" name="loai_hinh" required>
                                <option value="">Chọn loại hình</option>
                                <option value="mời giảng">Mời giảng</option>
                                <option value="đồ án">Đồ án</option>
                            </select>
                        </div>

                        <button type="submit" class="submit-btn">
                            <i class="bi bi-plus-circle me-2"></i>Thêm hệ đào tạo
                        </button>
                    </form>
                </div>
            </section>

            <section class="he-dao-tao-card">
                <div class="he-dao-tao-card__header">
                    <div class="toolbar">
                        <div class="toolbar-title">
                            <h2>Danh Sách Hệ Đào Tạo</h2>
                            <p>Lọc nhanh theo tên hệ, cấp độ hoặc loại hình.</p>
                        </div>

                        <div class="toolbar-search-wrap">
                            <input
                                type="text"
                                id="searchHeDaoTao"
                                class="toolbar-search"
                                placeholder="Tìm theo tên hoặc loại hình..."
                            />
                        </div>
                    </div>
                </div>

                <div class="he-dao-tao-card__body">
                    <div class="table-shell">
                        <table id="heDaoTaoTable" class="table align-middle">
                            <thead>
                                <tr>
                                    <th style="width: 90px;">ID</th>
                                    <th>Tên hệ đào tạo</th>
                                    <th style="width: 120px;">Cấp độ</th>
                                    <th style="width: 170px;">Loại hình</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (heDaoTaoList && heDaoTaoList.length > 0) { %>
                                    <% heDaoTaoList.forEach(function(item) { %>
                                        <tr>
                                            <td>
                                                <span class="id-badge"><%= item.id %></span>
                                            </td>
                                            <td><strong><%= item.he_dao_tao %></strong></td>
                                            <td>
                                                <span class="level-chip"><%= item.cap_do %></span>
                                            </td>
                                            <td>
                                                <span class="type-badge <%= item.loai_hinh === 'mời giảng' ? 'type-badge--moi-giang' : 'type-badge--do-an' %>">
                                                    <%= item.loai_hinh %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" class="text-center empty-state">Chưa có hệ đào tạo nào.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <script>
        document.getElementById("searchHeDaoTao").addEventListener("keyup", function () {
            const keyword = this.value.toLowerCase().trim();
            const rows = document.querySelectorAll("#heDaoTaoTable tbody tr");

            rows.forEach((row) => {
                const rowText = row.textContent.toLowerCase();
                row.style.display = rowText.includes(keyword) ? "" : "none";
            });
        });

        const successMessage = <%- JSON.stringify(message || "") %>;
        const errorMessage = <%- JSON.stringify(error || "") %>;

        if (successMessage) {
            Swal.fire({
                icon: "success",
                title: "Thêm thành công",
                text: successMessage,
                confirmButtonText: "OK"
            });
        }

        if (errorMessage) {
            Swal.fire({
                icon: "error",
                title: "Thêm thất bại",
                text: errorMessage,
                confirmButtonText: "Đóng"
            });
        }
    </script>
</body>

</html>
