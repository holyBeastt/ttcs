<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NCKH V3 - Thống Kê Học Viện</title>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.min.css" rel="stylesheet" />

  <link rel="stylesheet" href="/css/admin.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/nckh_v3.css" />

  <style>
    .nckh-v3-list-wrap { padding: 16px; max-width: 1700px; margin: 0 auto; }
    .nckh-v3-list-toolbar { display: flex; align-items: flex-end; gap: 12px; flex-wrap: wrap; margin-bottom: 16px; }
    .nckh-v3-list-toolbar .form-select, .nckh-v3-list-toolbar .form-control, .nckh-v3-list-toolbar .btn { margin-top: 0 !important; margin-bottom: 0 !important; }
    .nckh-v3-list-toolbar .toolbar-item { min-width: 180px; }
    .nckh-v3-list-toolbar .toolbar-item select { height: 42px; }
    .nckh-v3-list-toolbar .toolbar-action { display: flex; align-items: flex-end; gap: 8px; }
    .nckh-v3-list-toolbar .toolbar-action button { height: 42px; min-width: 140px; display: inline-flex; align-items: center; justify-content: center; line-height: 1.2; }
    .nckh-v3-list-table { background: #fff; border: 1px solid #dee2e6; border-radius: 10px; overflow: hidden; box-shadow: 0 2px 10px rgba(0, 0, 0, .06); }
    .nckh-v3-list-table .table { margin-bottom: 0; }
    .nckh-v3-list-table thead th { background: #3eacff; color: #fff; border-color: #2d7fbe; text-transform: uppercase; font-size: .78rem; white-space: nowrap; }
    .nckh-v3-kpi { border: 1px solid #e9ecef; border-radius: 10px; background: #fff; padding: 16px; text-align: center; }
    .nckh-v3-kpi .label { color: #6c757d; font-size: .88rem; }
    .nckh-v3-kpi .value { font-size: 1.4rem; font-weight: 700; margin-top: 6px; }
    .nckh-v3-section-title { margin: 18px 0 10px; font-weight: 700; }
  </style>
</head>

<body>
  <%- include('../header') %>

  <div class="nckh-v3-list-wrap">
    <div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h1 class="page-title mb-0">Thống kê NCKH theo học viện</h1>
      <div class="d-flex gap-2">
        <a href="/v3/nckh/xem-chung" class="btn btn-outline-secondary btn-sm">Danh sách NCKH</a>
        <a href="/v3/nckh/thong-ke/giang-vien" class="btn btn-outline-primary btn-sm">TK theo GV</a>
        <a href="/v3/nckh/thong-ke/khoa" class="btn btn-outline-primary btn-sm">TK theo Khoa</a>
      </div>
    </div>

    <div class="nckh-v3-list-toolbar">
      <div class="toolbar-item">
        <select id="namHocFilter" class="form-select"></select>
      </div>
      <div class="toolbar-action">
        <button id="loadDataBtn" class="btn btn-primary">
          <i class="bi bi-search"></i> Hiển thị
        </button>
        <button id="exportExcelBtn" class="btn btn-success">
          <i class="bi bi-file-earmark-excel"></i> Xuất Excel
        </button>
      </div>
    </div>

    <div class="row g-3 mb-2">
      <div class="col-md-4"><div class="nckh-v3-kpi"><div class="label">Tổng công trình</div><div class="value" id="kpiCongTrinh">0</div></div></div>
      <div class="col-md-4"><div class="nckh-v3-kpi"><div class="label">Tổng số tiết</div><div class="value" id="kpiSoTiet">0</div></div></div>
      <div class="col-md-4"><div class="nckh-v3-kpi"><div class="label">Giảng viên tham gia</div><div class="value" id="kpiGiangVien">0</div></div></div>
    </div>

    <h6 class="nckh-v3-section-title">Thống kê theo loại NCKH</h6>
    <div class="nckh-v3-list-table table-responsive">
      <table class="table table-bordered table-hover text-center align-middle">
        <thead>
          <tr>
            <th>STT</th>
            <th class="text-start">Loại NCKH</th>
            <th>Số công trình</th>
            <th>Tổng số tiết</th>
            <th width="80">Chi tiết</th>
          </tr>
        </thead>
        <tbody id="typeTableBody"></tbody>
      </table>
    </div>

    <h6 class="nckh-v3-section-title">Thống kê theo khoa</h6>
    <div class="nckh-v3-list-table table-responsive">
      <table class="table table-bordered table-hover text-center align-middle">
        <thead>
          <tr>
            <th>STT</th>
            <th>Mã phòng ban</th>
            <th class="text-start">Tên khoa</th>
            <th>Số công trình</th>
            <th>Tổng số tiết</th>
            <th width="80">Chi tiết</th>
          </tr>
        </thead>
        <tbody id="facultyTableBody"></tbody>
      </table>
    </div>

  </div>

  <!-- Modal Chi Tiết -->
  <div class="modal fade" id="recordsModal" tabindex="-1" aria-labelledby="recordsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header bg-primary text-white">
          <h5 class="modal-title" id="recordsModalLabel">Chi tiết công trình NCKH</h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-3 bg-light">
          <div class="nckh-v3-list-table table-responsive">
            <table class="table table-bordered table-striped table-hover mb-0 align-middle bg-white">
              <thead class="text-center">
                <tr>
                  <th width="50">STT</th>
                  <th>Tên công trình</th>
                  <th width="150">Loại công trình</th>
                  <th width="150">Phân loại</th>
                  <th width="150">Tác giả chính</th>
                  <th width="150">Thành viên</th>
                  <th width="100">Số tiết</th>
                  <th width="100">Mã số</th>
                  <th width="100">Ngày NT</th>
                </tr>
              </thead>
              <tbody id="modalTableBody">
                <tr>
                  <td colspan="9" class="text-center py-4">Đang tải dữ liệu...</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
        </div>
      </div>
    </div>
  </div>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.all.min.js"></script>
  <script src="/js/nckh_v3/stats/common.js"></script>
  <script src="/js/nckh_v3/stats/institute.js"></script>
</body>

</html>
