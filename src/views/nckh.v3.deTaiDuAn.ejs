<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NCKH V3 - De tai du an</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <style>
    .v3-wrap { max-width: 1240px; margin: 20px auto; padding: 0 16px; }
    .v3-card { border: 1px solid #d9d9d9; border-radius: 12px; padding: 16px; margin-bottom: 16px; background: #fff; }
    .multi-select { min-height: 130px; }
    .table td, .table th { vertical-align: middle; }
  </style>
</head>
<body>
  <%- include('header') %>

  <div class="v3-wrap">
    <h3 class="mb-3">NCKH V3 - De tai du an</h3>

    <div class="v3-card">
      <form id="deTaiForm" class="row g-3">
        <div class="col-md-6">
          <label class="form-label">Ten cong trinh</label>
          <input id="tenCongTrinh" class="form-control" required />
        </div>

        <div class="col-md-3">
          <label class="form-label">Phan loai</label>
          <input id="phanLoai" class="form-control" placeholder="VD: Cap Bo" required />
        </div>

        <div class="col-md-3">
          <label class="form-label">Nam hoc</label>
          <input id="namHoc" class="form-control" placeholder="2025-2026" required />
        </div>

        <div class="col-md-3">
          <label class="form-label">Tong so tiet</label>
          <input id="tongSoTiet" type="number" min="0" step="0.01" class="form-control" required />
        </div>

        <div class="col-md-3">
          <label class="form-label">Khoa</label>
          <select id="khoaId" class="form-select" required></select>
        </div>

        <div class="col-md-3">
          <label class="form-label">Tac gia (cho phep nhieu)</label>
          <select id="tacGiaIds" class="form-select multi-select" multiple required></select>
        </div>

        <div class="col-md-3">
          <label class="form-label">Thanh vien (cho phep nhieu)</label>
          <select id="thanhVienIds" class="form-select multi-select" multiple></select>
        </div>

        <div class="col-12">
          <button id="submitBtn" type="submit" class="btn btn-primary">Them de tai</button>
          <button id="resetBtn" type="button" class="btn btn-outline-secondary ms-2">Lam moi</button>
        </div>
      </form>
    </div>

    <div class="v3-card">
      <div class="row g-3 align-items-end">
        <div class="col-md-3">
          <label class="form-label">Loc nam hoc</label>
          <input id="filterNamHoc" class="form-control" placeholder="2025-2026" />
        </div>

        <div class="col-md-3">
          <label class="form-label">Loc khoa</label>
          <select id="filterKhoaId" class="form-select"></select>
        </div>

        <div class="col-md-3">
          <button id="reloadBtn" type="button" class="btn btn-dark">Tai lai du lieu</button>
        </div>
      </div>

      <div class="table-responsive mt-3">
        <table class="table table-bordered table-striped">
          <thead>
            <tr>
              <th>STT</th>
              <th>Ten cong trinh</th>
              <th>Phan loai</th>
              <th>Nam hoc</th>
              <th>Tong tiet</th>
              <th>Khoa</th>
              <th>Khoa duyet</th>
              <th>Vien duyet</th>
              <th>Thao tac</th>
            </tr>
          </thead>
          <tbody id="deTaiTableBody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <script src="/js/nckh_v3/de_tai_du_an/api.js"></script>
  <script src="/js/nckh_v3/de_tai_du_an/mapper.js"></script>
  <script src="/js/nckh_v3/de_tai_du_an/form.js"></script>
  <script src="/js/nckh_v3/de_tai_du_an/grid.js"></script>
  <script src="/js/nckh_v3/de_tai_du_an/index.js"></script>
</body>
</html>
