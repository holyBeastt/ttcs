    <link
      href="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.min.css"
      rel="stylesheet"
    />
    <!-- SweetAlert2 JavaScript -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.all.min.js"></script>

    <!-- link thư viện excel  -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.3/xlsx.full.min.js"></script>

    <!-- AG Grid Styles -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/ag-grid-community/styles/ag-grid.css"
    />
    <link
      rel="stylesheet"
      href="https://unpkg.com/ag-grid-community/styles/ag-theme-alpine.css"
    />

    <!-- AG Grid Script -->
    <!-- <script src="https://unpkg.com/ag-grid-community@29.3.2/dist/ag-grid-community.min.js"></script> -->

    <script src="/js/TKB/ag-grid-community.min.js"></script>

    <!-- Toastify  -->
    <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css"
    />


    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const isKhoa = localStorage.getItem("isKhoa");
        const role = localStorage.getItem("userRole");

        // hideButton2 ẩn các chức năng thêm sửa xóa
        hideButtonTKB(role);
      });

      function hideButtonTKB(role) {
        if (role != "<%= APP_ROLES.troLy_phong %>" && role != "<%= APP_ROLES.lanhDao_phong %>") {
          const deleteTKB = document.getElementById("xoa-TKB");
          const themBtn = document.getElementById("add-row-btn");
          const addToQCDK = document.getElementById("them-vao-qc-du-kien");
          //const xuatFileBtn = document.getElementById("export-file-btn");

          if (deleteTKB) {
            deleteTKB.style.display = "none"; // Ẩn ngay lập tức
            setTimeout(() => deleteTKB.remove(), 100); // Xóa sau 100ms để tránh lag
          }
          if (themBtn) themBtn.remove();
          //xuatFileBtn.style.display = "none";

          if (addToQCDK) addToQCDK.remove();
        } else {
          const addToQCDK = document.getElementById("them-vao-qc-du-kien");
          if (addToQCDK) addToQCDK.style.display = "block";
        }
      }
    </script>

    <!-- render bảng -->
    <script>
      // Biến chung để lưu dữ liệu render
      var renderData = [];
      // Mảng khoa ( để validate bảng)
      var khoaArray = [];

      let gridApi; // Biến toàn cục để lưu trữ gridApi

      // Biến lưu danh sách hệ đào tạo
      let heDaoTaoList = [];
      let heDaoTaoMap = {};

      async function getDataTable() {

        heDaoTaoList = JSON.parse(
          localStorage.getItem('HE_DAO_TAO_CACHE')
        ) || [];

        console.log('heDaoTaoList:', heDaoTaoList);

        // reset map
        heDaoTaoMap = {};

        heDaoTaoList.forEach(item => {
          heDaoTaoMap[item.id] = item.tenHe;
        });


        // 1. Get current filter values
        const Dot = document.getElementById("combobox-dot").value;
        const Ki = document.getElementById("comboboxki").value;
        const Nam = document.getElementById("NamHoc").value;
        const Khoa = document.getElementById("departmentFilter").value;

        const body = {
          Khoa: Khoa,
          Dot: Dot,
          Ki: Ki,
          Nam: Nam,
        };

        try {
          // 2. Show loading overlay if grid exists
          if (gridApi) gridApi.showLoadingOverlay();

          // 3. Call API (Using your POST endpoint)
          const response = await fetch("/api/v1/tkb/data-tkb-to-render", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify(body),
          });

          if (!response.ok) {
            throw new Error("Network response was not ok: " + response.statusText);
          }

          const data = await response.json();
          
          // 4. Update global data variable
          renderData = data; 

          // 5. SMART UPDATE: Check if Grid exists
          if (gridApi) {
            // If grid exists, just swap the data inside (No flicker)
            gridApi.setRowData(renderData);

            // Handle Empty State
            if (renderData.length === 0) {
              gridApi.showNoRowsOverlay();
            } else {
              gridApi.hideOverlay();
            }
            
            console.log("♻️ Data updated via AG Grid API");
          } else {
            // If grid doesn't exist yet, build it from scratch
            renderTable();
          }

        } catch (error) {
          console.error("Error fetching data:", error);
          if (gridApi) gridApi.hideOverlay(); // Hide loading if error
          Swal.fire({
              title: "Lỗi",
              text: "Có lỗi xảy ra khi gọi API: " + error.message,
              icon: "error"
          });
        }
      }

      let gridOptions; // Khai báo biến toàn cục

      function renderTable() {
        const role = localStorage.getItem("userRole");
        const rowHeight = 50; // Chiều cao mỗi dòng

        // ✅ 2. OPTIMIZATION: If grid already exists, just update data and stop.
        // This prevents the table from being destroyed and recreated.
        if (gridApi) {
          gridApi.setRowData(renderData);
          
          // Handle empty data display inside the grid
          if (renderData.length === 0) {
            gridApi.showNoRowsOverlay();
          } else {
            gridApi.hideOverlay();
          }
          return; // ⛔ EXIT FUNCTION HERE
        }

        // Handle case where Grid doesn't exist yet and there is no data
        if (renderData.length === 0) {
          document.getElementById("table-container").innerHTML = "<p class='text-center mt-3'>Không có dữ liệu</p>";
          return;
        }

        const headersMap = {
          id: { name: "ID", width: 70 },
          major: { name: "Khoa", width: 100 },
          // ll_code: {
          //   name: "CTĐT",
          //   width: 0,
          // },
          ll_total: { name: "LL", width: 50 },
          student_quantity: { name: "Số SV", width: 70 },
          student_bonus: { name: "HS lớp đông", width: 100 },
          bonus_time: { name: "HS ngoài giờ", width: 90 },
          course_id: { name: "Mã học phần", width: 100 },
          lecturer: { name: "Giảng viên theo TKB", width: 150 },
          credit_hours: { name: "Số TC", width: 80 },
          course_name: { name: "Lớp học phần", width: 250 },
          course_code: { name: "Mã học phần", width: 100 },
          start_date: { name: "Ngày bắt đầu", width: 110 },
          end_date: { name: "Ngày kết thúc", width: 110 },
          qc: { name: "QC", width: 70 },
          he_dao_tao: { name: "Hệ đào tạo", width: 150 },
          semester: { name: "Năm học", width: 100 },
        };

        let canEdit = false;

        if (role == "<%= APP_ROLES.troLy_phong %>" || role == "<%= APP_ROLES.lanhDao_phong %>") {
          canEdit = true;
        }

        const columnDefs = [
          {
            headerName: "STT",
            field: "stt",
            valueGetter: (params) => params.node.rowIndex + 1, // Đánh số thứ tự
            width: 70,
            editable: false,
            cellStyle: { fontWeight: "bold", textAlign: "center" },
          },
          ...Object.keys(renderData[0])
            .filter((key) => key !== "GhiChu" && key !== "description")
            .map((key) => ({
              field: key,
              headerName: headersMap[key]?.name || key,
              width: headersMap[key]?.width || 100,
              editable: canEdit && key !== "student_bonus" && key !== "id",
              hide: key === "semester" || key === "id" || key === "tt" || key === "course_id" 
              || key === 'dot' || key === 'ki_hoc' || key === 'nam_hoc' || key === 'note', // Ẩn cột không cần thiết
              headerClass: "custom-header",
              filter: false,

              valueGetter: (params) => {
                const field = params.colDef.field;

                if (field === "start_date" || field === "end_date") {
                  const value = params.data[field];
                  if (!value) return "";

                  const date = new Date(value);
                  if (isNaN(date.getTime())) return value;

                  return reFormatDateFromDB(value); // Luôn trả STRING
                }

                return params.data[field];
              },

              valueSetter: (params) => {
                const field = params.colDef.field;
                const oldValue = params.data[field];
                const rawValue = params.newValue;
                const value =
                  typeof rawValue === "string"
                    ? rawValue.trim()
                    : rawValue;
                // ✅ Xử lý riêng cho cột "start_date" và "end_date"
                if (field === "start_date" || field === "end_date") {
                  if (!value) return false;

                  const parts = value.split("/");
                  if (parts.length === 3) {
                    // Đảm bảo thêm số 0 ở đầu nếu người dùng nhập thiếu (vd: 9 -> 09)
                    const day = parts[0].padStart(2, "0");
                    const month = parts[1].padStart(2, "0");
                    const year = parts[2];
                    
                    // Tạo chuỗi chuẩn ISO: yyyy-mm-dd
                    const formattedIsoDate = `${year}-${month}-${day}`; 

                    const date = new Date(formattedIsoDate);

                    // Kiểm tra ngày hợp lệ
                    if (!isNaN(date.getTime())) {
                      console.log("✅ Valid date to save:", formattedIsoDate);
                      
                      // QUAN TRỌNG: Lưu chuỗi chuẩn ISO vào data, KHÔNG lưu chuỗi dd/mm/yyyy
                      params.data[field] = formattedIsoDate; 
                      
                      return true;
                    }
                  }
                  Toastify({
                    text: "❌ Ngày không hợp lệ! Vui lòng kiểm tra lại (dd/mm/yyyy)",
                    duration: 3000,      // Nên để lâu hơn (3s) để user kịp đọc
                    gravity: "top",
                    position: "right",
                    stopOnFocus: true,   // Di chuột vào sẽ dừng biến mất (để user đọc kỹ hơn)
                    backgroundColor: "#FF5252", // Màu đỏ (Error) hoặc dùng "#FFA000" (Cam - Warning)
                  }).showToast();


                  console.warn("❌ Invalid date format:", value);
                  params.data[field] = oldValue;
                  return false;
                }

                // ✅ Xử lý các cột khác
                if (value !== oldValue) {
                  params.data[field] = value;
                  return true;
                }

                return false;
              },

              cellEditor: "agTextCellEditor",
              cellEditorParams: {
                useFormatter: true, // Giữ nguyên định dạng khi chỉnh sửa
              },
            })),
        ];

        // Lấy từ localStorage và convert thành mảng string
        const stored = JSON.parse(localStorage.getItem("KhoaList")) || [];
        const khoaArray = stored.map(item => item.MaPhongBan);

        // Gắn combobox cho cột Khoa
        const khoaCol = columnDefs.find(col => col.field === "major");

        const heDaoTaoCol = columnDefs.find(col => col.field === "he_dao_tao");

        if (khoaCol) {
          khoaCol.cellEditor = "agSelectCellEditor";
          khoaCol.cellEditorParams = { values: khoaArray };
        }

        if (heDaoTaoCol) {
          heDaoTaoCol.cellEditor = "agSelectCellEditor";
          heDaoTaoCol.cellEditorParams = {
            values: heDaoTaoList.map(item => item.id),
          };
          heDaoTaoCol.valueFormatter = (params) =>
            heDaoTaoMap[params.value] || "";
        }

        columnDefs.push({
          headerName: "Ghi chú",
          field: "note",
          width: 150,
          editable: (params) => {
            const field = params.colDef.field;

            // ✅ TẤT CẢ ROLE đều sửa được NOTE
            if (field === 'note') return true;

            // ❌ role không có quyền → không sửa gì thêm
            if (!canEdit) return false;

            // ❌ các cột cấm sửa
            if (['id', 'student_bonus'].includes(field)) return false;

            return true;
          },

          cellEditor: "agLargeTextCellEditor",
          cellEditorPopup: true,
          cellEditorParams: {
            maxLength: 400,
            rows: 6,
            cols: 40,
          },
        });

        // Thêm cột "Hành động" nếu role là "<%= APP_ROLES.troLy_phong %>" hoặc "<%= APP_ROLES.lanhDao_phong %>"
        if (role === "<%= APP_ROLES.troLy_phong %>" || role === "<%= APP_ROLES.lanhDao_phong %>") {
          columnDefs.push({
            headerName: "Xóa",
            field: "actions",
            editable: false,
            width: 60,
            cellRenderer: (params) => {
              const id = params.data.id; // Lấy ID từ dữ liệu
              const dot = params.data.dot; // Lấy giá trị `dot` từ dữ liệu
              const ki_hoc = params.data.ki_hoc; // Lấy giá trị `ki_hoc` từ dữ liệu
              const nam_hoc = params.data.nam_hoc; // Lấy giá trị `nam_hoc` từ dữ liệu
              const stt = params.node.rowIndex + 1; // Lấy STT của dòng
              return `<button onclick="deleteRow('${id}', '${dot}', '${ki_hoc}', '${nam_hoc}', ${stt})">Xóa</button>`;
            },
          });
        }

        // Xử lý khi ô được chỉnh sửa
        async function onCellValueChanged(event) {
          console.log("Cell value changed:", event);
          const { data, colDef, newValue, oldValue } = event;
          const id = data.id;

          const field = colDef.field;

          try {
            const response = await fetch("/api/v1/tkb/update-row", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id, field, value: newValue, oldValue, data }),
            });

            const updatedRow = await response.json();

            if (response.ok) {
              const rowNode = gridOptions.api.getRowNode(id); // lúc đầu là id
              if (rowNode) {
                rowNode.setData(updatedRow); // Cp nhật data của row
              } else {
                console.error(
                  "⚠️ Không tìm thấy dòng để cập nhật:",
                  updatedRow
                );
              }

              // ✅ Hiển thị thông báo thành công
              Toastify({
                text: "✅ Cập nhật thành công!",
                duration: 1000, // Hiển thị trong 3 giây
                gravity: "top", // Đưa thông báo lên trên
                position: "right", // Căn lề bên phải
                backgroundColor: "#4CAF50", // Màu xanh lá (thành công)
              }).showToast();
            } else {
              Swal.fire({
                title: "❌ Lỗi",
                html: updatedRow.message,
                icon: "error",
                confirmButtonText: "OK",
                width: "auto",
                padding: "20px",
              });
            }
          } catch (error) {
            console.error("❌ Lỗi kết nối server:", error);
          }
        }

        // Tạo bảng AG Grid
        gridOptions = {
          getRowId: (params) => params.data.id, // Xác định dòng theo `id`
          columnDefs: columnDefs,
          rowData: renderData,
          defaultColDef: {
            resizable: true,
            sortable: true,
            filter: false,
            editable: false,
            cellStyle: {
              fontSize: "14px", // Giảm cỡ chữ
              whiteSpace: "normal", // Cho phép xuống dòng
              wordWrap: "break-word", // Tự động ngắt dòng nếu quá dài
              textAlign: "center", // Căn giữa nội dung ô
            },
          },
          rowHeight: rowHeight,
          onCellValueChanged: onCellValueChanged, // Gọi khi ô thay đổi
          singleClickEdit: true, // Nhấn vào ô là có thể sửa ngay
          enterMovesDownAfterEdit: true, // Nhấn Enter hoặc mũi tên xuống sẽ xuống ô tiếp theo
          suppressClickEdit: false, // Cho phép click vào ô để sửa ngay

          // 🔥 NEW: Capture API when grid is ready
          onGridReady: (params) => {
              gridApi = params.api; // Assign to global variable
              params.api.sizeColumnsToFit(); // Resize columns
          },
          // Optional: Templates for empty states
          overlayNoRowsTemplate: '<span style="padding: 10px;">Không có dữ liệu</span>',
        };

        const tableContainer = document.getElementById("table-container");
        tableContainer.innerHTML = ""; // Xóa nội dung cũ trước khi tạo bảng mới
        new agGrid.Grid(tableContainer, gridOptions);

        // ✅ THÊM ĐOẠN NÀY: Xử lý tìm kiếm Global từ bên ngoài
        const searchInput = document.getElementById("find-by-class-name");
        if (searchInput) {
            searchInput.addEventListener("input", function (e) {
                if (gridApi) {
                    // Tính năng tìm kiếm nhanh trên toàn bộ dữ liệu đang hiển thị
                    gridApi.setQuickFilter(e.target.value); 
                }
            });
        }
        // ✅ Tự động căn chỉnh cột
        // setTimeout(() => {
        //   gridOptions.api.sizeColumnsToFit();
        // }, 100);
      }

      function reFormatDateFromDB(input) {
        if (!input) return "";
          const date = new Date(input);

        if (isNaN(date.getTime())) {
          return input;
        }

        const day = String(date.getDate()).padStart(2, "0");
        const month = String(date.getMonth() + 1).padStart(2, "0");
        const year = date.getFullYear();

        return `${day}/${month}/${year}`;
      }

      async function addNewRow() {
        let Dot = document.getElementById("combobox-dot").value;
        let Ki = document.getElementById("comboboxki").value;
        let Nam = document.getElementById("NamHoc").value;
        let Khoa = document.getElementById("departmentFilter").value;

        try {
          const response = await fetch("/api/v1/TKB/add-new_row", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
              dot: Dot,
              ki_hoc: Ki,
              nam_hoc: Nam,
              major: Khoa,
              course_name: "",
              lecturer: "Giảng viên",
              student_quantity: 0,
              student_bonus: 0,
              bonus_time: 0,
              ll_code: 0,
              ll_total: 0,
              qc: 0,
              he_dao_tao: "Đại học (Đóng học phí)",
              bonus_time: 1,
            }),
          });

          const newRow = await response.json();
          if (response.ok) {

            // Thêm vào renderData
            //renderData.push(newRow.data);

            // ✅ Thêm dòng mới vào bảng AG Grid
            gridOptions.api.applyTransaction({ add: [newRow.data] });

            // ✅ Lấy số lượng hàng hiện tại và cuộn xuống dòng cuối cùng
            setTimeout(() => {
              const lastRowIndex = gridOptions.api.getDisplayedRowCount() - 1;
              gridOptions.api.ensureIndexVisible(lastRowIndex);
            }, 100);
          } else {
            console.error("❌ Lỗi khi thêm dòng:", newRow.message);
          }
        } catch (error) {
          console.error("❌ Lỗi kết nối server:", error);
        }
      }

      async function deleteRow(id, dot, ki_hoc, nam_hoc, stt) {

        if (confirm(`Bạn có chắc chắn muốn xóa dòng ${stt} ?`)) {
          try {
            const response = await fetch(`/TKB-delete-row?id=${id}`, {
              method: "DELETE",
              headers: {
                "Content-Type": "application/json",
              },
            });

            if (!response.ok) {
              throw new Error(`Xóa dòng thất bại: ${response.statusText}`);
            }

            // XÓA ĐÚNG CÁI DÒNG TRONG AG GRID
            gridOptions.api.applyTransaction({
              remove: [{ id }]
            });
            console.log("Dòng đã xóa khỏi AG Grid", renderData);

            // XÓA TRONG RENDERDATA
            renderData = renderData.filter(row => row.id !== id);

            console.log("Dòng đã xóa thành công", renderData);

            Toastify({
              text: "✅ Xóa thành công!",
              duration: 1000,
              gravity: "top",
              position: "right",
              backgroundColor: "#4CAF50",
            }).showToast();

          } catch (error) {
            console.error("Lỗi khi xóa dòng:", error);
            alert(`Có lỗi xảy ra khi xóa: ${error.message}`);
          }
        }
      }

