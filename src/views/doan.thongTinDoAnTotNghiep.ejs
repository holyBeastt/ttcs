    <!-- Phần xuất file -->
    <script>

      async function exportToExcel() {
        if (!globalData || globalData.length === 0) {
          Swal.fire({
            title: 'Thông báo',
            html: "Không có dữ liệu để xuất file",
            icon: 'warning',
            confirmButtonText: 'OK',
            width: 'auto',
            padding: '20px',
          });
          return;
        }

        // Lấy giá trị từ các combo box để tạo tên file
        const dot = document.getElementById('combobox-dot').value;
        const ki = document.getElementById('combobox-ki').value;
        const namHoc = document.getElementById('NamHoc').value;
        const maPhongBan = document.getElementById('MaPhongBan').value;
        const heDaoTao = document.getElementById('he_dao_tao').value;

        try {
          // Gửi dữ liệu đến controller để xử lý
          const response = await fetch("/doan-export-excel", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ renderData: globalData }),
          });

          if (!response.ok) {
            throw new Error(`Failed to export: ${response.statusText}`);
          }

          // Tạo blob từ response
          const blob = await response.blob();
          const url = window.URL.createObjectURL(blob);
          const a = document.createElement("a");
          a.href = url;
          a.download = `do_an_tot_nghiep_${dot}_${ki}_${namHoc}_${maPhongBan}_${heDaoTao}.xlsx`;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          window.URL.revokeObjectURL(url);

          Swal.fire({
            title: 'Thông báo',
            html: "Xuất file thành công!",
            icon: 'success',
            confirmButtonText: 'OK',
            width: 'auto',
            padding: '20px',
          });

        } catch (error) {
          console.error("Error exporting data:", error);
          Swal.fire({
            title: 'Thông báo',
            html: "Có lỗi xảy ra khi xuất file",
            icon: 'error',
            confirmButtonText: 'OK',
            width: 'auto',
            padding: '20px',
          });
        }
      }
    </script>
  </body>
