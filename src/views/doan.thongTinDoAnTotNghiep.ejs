          checkAllId = `checkAll${type.charAt(0).toUpperCase() + type.slice(1)}`;
        }
        
        const checkAllCheckbox = document.getElementById(checkAllId);

        if (checkAllCheckbox) {
          // Ngăn không cho người dùng thay đổi checkbox tổng
