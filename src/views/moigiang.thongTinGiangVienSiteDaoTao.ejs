          },
          body: JSON.stringify(globalData), // Chuyển đổi globalData thành chuỗi JSON
        })
        .then((response) => {
          if (!response.ok) {
            throw new Error("Lỗi khi gửi dữ liệu");
          }
          return response.json(); // Chuyển đổi phản hồi thành JSON
        })
        .then((data) => {
          // console.log('Dữ liệu phản hồi từ server:', data);
          Swal.fire({
            title: 'Thông báo',
