        daoTaoCheckbox.type = "checkbox";
        daoTaoCheckbox.name = "daoTao"; // Thêm thuộc tính name
        daoTaoCheckbox.checked = row.DaoTaoDuyet || false; // Dùng một trường cho checkbox
