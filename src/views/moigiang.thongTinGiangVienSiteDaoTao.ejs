            padding: '20px', // Giữ khoảng cách cho nội dung
          });
        })
        .catch((error) => {
          console.error("Có lỗi xảy ra:", error);
          Swal.fire({
            title: 'Thông báo',
            html: "Có lỗi xảy ra khi cập nhật dữ liệu",
            icon: 'error',
            confirmButtonText: 'OK',
            width: 'auto', // Tự động điều chỉnh chiều rộng
            padding: '20px', // Giữ khoảng cách cho nội dung
          });
        });
    }

