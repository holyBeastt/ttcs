  <script>
    let globalData = []; // Biến toàn cục để lưu dữ liệu từ server
    let nameGv = []; // Biến toàn cục để lưu tất cả tên giảng viên
    let nameGvm = []; // Biến toàn cục để lưu tên giảng viên theo khoa
    let rs = [];
    var boMon = [];
    let phongBanList = [];
    let tongTiet;
    
    // Danh sách hệ đào tạo từ API
    var heDaoTaoList = [];

    // Hàm load danh sách hệ đào tạo từ API
    async function loadHeDaoTaoFromAPI() {
      try {
        const response = await fetch('/api/gvm/v1/he-moi-giang');
        if (!response.ok) {
          throw new Error('Failed to fetch he dao tao list');
        }
        const result = await response.json();
        
        if (result.success && result.data) {
          // Chuyển đổi data từ API sang format phù hợp
          // API trả về: {id: 1, he_dao_tao: "Tên hệ"}
          // Chuyển thành: {id: 1, tenHe: "Tên hệ"}
          // Đảm bảo id luôn là số để so sánh chính xác
          heDaoTaoList = result.data.map(item => ({
            id: typeof item.id === 'string' ? parseInt(item.id, 10) : item.id,
            tenHe: item.he_dao_tao
          }));
          console.log('Đã load danh sách hệ đào tạo từ API:', heDaoTaoList);

          // Cập nhật options của select#heDaoTao
          const heDaoTaoSelect = document.getElementById('heDaoTao');
          if (heDaoTaoSelect) {
            heDaoTaoSelect.innerHTML = '<option value="ALL">Tất cả hệ</option>';
            heDaoTaoList.forEach(item => {
              const opt = document.createElement('option');
              opt.value = item.id;
              opt.textContent = item.tenHe;
              heDaoTaoSelect.appendChild(opt);
            });
          }
        } else {
          console.error('API không trả về dữ liệu hợp lệ');
          heDaoTaoList = [];
        }
      } catch (error) {
        console.error('Lỗi khi gọi API hệ đào tạo:', error);
        heDaoTaoList = [];
      }
    }

    // Helper function: Lấy tên hệ đào tạo từ id
    function getTenHeById(heId) {
      if (!heId || heDaoTaoList.length === 0) return heId || '';
      const heIdNumber = typeof heId === 'string' ? parseInt(heId, 10) : heId;
      const found = heDaoTaoList.find(item => item.id === heIdNumber);
      return found ? found.tenHe : heId;
    }

