    const loadDataPopup = async (tongTiet) => {
      const summaryBox = document.getElementById("summaryBox");
      summaryBox.innerHTML = ""; // clear cũ

      let blocks = [];

      if (tongTiet.thongKeTheoKhoa && tongTiet.thongKeAll) {
        tongTiet.thongKeTheoKhoa.forEach((item) => {
          const block = renderBlock(item);
          summaryBox.appendChild(block);
          blocks.push(block);
        });

        // Render ALL
        summaryBox.appendChild(renderBlock(tongTiet.thongKeAll));
      } else {
        // Trường hợp chỉ có 1 object
        summaryBox.appendChild(renderBlock(tongTiet));
      }

      // Nếu nhiều hơn 5 block thì bật scroll
      if (blocks.length > 3) {
        summaryBox.style.maxHeight = "300px";
        summaryBox.style.overflowY = "auto";
      } else {
        summaryBox.style.maxHeight = "none";
        summaryBox.style.overflowY = "visible";
      }

      // Toggle hiển thị box tổng kết
      const toggleBtn = document.getElementById("toggleBtn");
      const arrowIcon = document.getElementById("arrowIcon");

      let isVisible = true;
      summaryBox.style.display = "block";

      toggleBtn.onclick = () => {
        isVisible = !isVisible;
        summaryBox.style.display = isVisible ? "block" : "none";
        arrowIcon.style.transform = isVisible ? "rotate(180deg)" : "rotate(0deg)";
      };
    };

          // Hàm render 1 block khoa
      const renderBlock = (item) => {
        const block = document.createElement("div");
        block.className = "khoa-summary";
        block.innerHTML = `
          <h4>Khoa: ${item.MaPhongBan}</h4>
          <p><b>Tổng tiết mời giảng:</b> ${item.tongTietMoiGiang} (${item.phanTramMoiGiang})</p>
          <p><b>Tổng tiết cơ hữu:</b> ${item.tongTietCoHuu} (${item.phanTramCoHuu})</p>
          <p><b>Tổng số tiết:</b> ${item.tongTietAll}</p>
        `;
        return block;
      };



