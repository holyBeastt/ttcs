              });
            }
          } catch (error) {
            alert("Lỗi khi gửi yêu cầu đến server: " + error);
          }
        } else {
          alert("ID của hàng hiện tại không tồn tại.");
        }
      } else {
        alert("currentRow không được xác định.");
      }

      closeNoteForm();
    }
    async function doneNote() {
      const note = document.getElementById("noteInput").value;
