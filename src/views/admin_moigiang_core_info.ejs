<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Thông tin giảng dạy cốt lõi</title>

  <link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css" />
  <link rel="stylesheet" href="/css/admin.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
  <link rel="stylesheet" href="/css/styles.css" />

  <!-- SweetAlert2 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.min.css" rel="stylesheet">
  <!-- Toastify CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css" />

  <style>
    /* CSS cho bảng — copy y nguyên từ TKB */
    .table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    .table th,
    .table td {
      padding: 10px;
      text-align: left;
      border: 1px solid #dee2e6;
      white-space: normal;
      word-wrap: break-word;
    }

    .table th {
      background-color: #007bff;
      color: white;
      font-weight: bold;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .table tbody tr:nth-child(even) {
      background-color: #f8f9fa;
    }

    .table tbody tr:hover {
      background-color: #e2e6ea;
    }

    .table td {
      vertical-align: middle;
    }

    .bg-custom {
      background-color: #f8f9fa;
      padding: 20px;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
    }

    .spinner-border {
      position: fixed;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      z-index: 1000;
    }

    .header-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 10px;
      justify-content: space-between;
    }

    .right {
      margin-top: 20px;
    }

    .btn {
      height: 45px;
      margin-left: 5px;
    }

    /* cảnh báo khi thiếu dữ liệu */
    .warning-row {
      background-color: #ffe6e6;
      color: #ff0000;
    }

    .tkb-input {
      width: 263px;
      padding: 8px;
      border: 1px solid #ccc;
      border-radius: 4px;
    }

    .tkb-input-container {
      margin-left: 5px;
      margin-bottom: 10px;
    }

    .custom-header {
      display: flex;
      justify-content: center;
      align-items: center;
      text-align: center !important;
    }

    .btn {
      padding: 6px 12px;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }

    .btn:hover {
      opacity: 0.8;
    }

    /* Kế thừa CSS từ styles.css cho các ID cũ */
    #mg-dot, #mg-ki, #mg-nam-hoc, #mg-khoa, #mg-he-dao-tao {
      width: 150px;
      color: #5476f0;
    }
    .selectop {
      padding: 0 10px !important;
    }
  </style>
</head>

<body>
  <%- include('adminHeader') %>

  <!-- Nội dung trang — cấu trúc giống hệt TKB -->
  <div class="container-fluid my-4" style="padding-left: 0px">
    <div class="flex-grow-1">
      <div class="header-actions">
        <div class="left">
          <button class="btn" id="them-vao-qc-du-kien" style="margin-bottom: 0px; display: none">
            Thêm vào quy chuẩn dự kiến
          </button>
        </div>

        <div class="right" style="margin-top: 0px">
          <div class="loc d-flex align-items-center">
            <!-- Combo box đợt -->
            <select class="selectop" id="mg-dot">
              <option value="">Đợt</option>
            </select>

            <!-- Combo box kì -->
            <select class="selectop" id="mg-ki">
              <option value="">Kì</option>
            </select>

            <!-- Combo box Năm -->
            <select class="selectop" id="mg-nam-hoc">
              <option value="">Chọn năm học</option>
            </select>
            <select class="selectop" id="mg-khoa">
              <option value="">Chọn khoa</option>
            </select>

            <!-- Combo box hệ đào tạo -->
            <select class="selectop" id="mg-he-dao-tao" style="width: max-content">
              <option value="ALL">Tất cả hệ đào tạo</option>
            </select>

            <button
              id="getData"
              class="btn text-nowrap"
              style="margin-top: 17px"
            >
              Hiển thị
            </button>
            <button
              class="btn text-nowrap"
              id="xoa-TKB"
              style="margin-top: 17px"
            >
              Xóa
            </button>
          </div>
        </div>
      </div>

      <div>
        <div class="tkb-input-container">
          <input
            type="text"
            placeholder="Tìm kiếm theo Tên..."
            class="search tkb-input"
            id="find-by-class-name"
          />
        </div>

        <!-- Bảng dữ liệu -->
        <div
          id="table-container"
          class="ag-theme-alpine"
          style="height: 500px; width: 100%"
        >
          <div id="myGrid" style="height: 100%; width: 100%;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- jQuery & Bootstrap -->
  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  
  <!-- SweetAlert2 & Toastify -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.6.16/dist/sweetalert2.all.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/toastify-js"></script>

  <!-- AG Grid (dùng file local giống TKB) -->
  <link rel="stylesheet" href="https://unpkg.com/ag-grid-community/styles/ag-grid.css">
  <link rel="stylesheet" href="https://unpkg.com/ag-grid-community/styles/ag-theme-alpine.css">
  <script src="/js/TKB/ag-grid-community.min.js"></script>

  <script>
    let gridOptions;
    let gridApi; // Khai báo biến toàn cục cho gridApi để tránh undefined ở bản v31+
    let globalData = [];

    // Biến lưu danh sách hệ đào tạo — giống hệt TKB
    let heDaoTaoList = [];
    let heDaoTaoMap = {};

    document.addEventListener("DOMContentLoaded", async function () {

      // Tải hệ đào tạo từ API (Đợt/Kỳ/NămHọc/Khoa dùng jQuery ready riêng bên dưới)
      await loadHeDaoTaoFromAPI();

      // Sự kiện nút hiển thị
      document.getElementById('getData').addEventListener('click', loadTableData);

      // Sự kiện tìm kiếm (như TKB)
      document.getElementById('find-by-class-name').addEventListener('input', function() {
        const text = this.value;
        if (gridApi) {
          if (gridApi.setGridOption) {
            gridApi.setGridOption('quickFilterText', text);
          } else if (typeof gridApi.setQuickFilter === 'function') {
            gridApi.setQuickFilter(text);
          }
        }
      });

      // Bắt event Xóa
      document.getElementById('xoa-TKB').addEventListener('click', function() {
         Swal.fire({
            title: 'Chưa khả dụng',
            text: 'Tính năng xóa chưa được triển khai cho module này!',
            icon: 'info'
         });
      });

      // Định nghĩa columns cho AG Grid - Y HỆT BÊN TKB VỀ THỨ TỰ VÀ STYLE
      const columnDefs = [
        { headerName: "STT", valueGetter: "node.rowIndex + 1", width: 70, pinned: 'left', cellStyle: { fontWeight: "bold", textAlign: "center" } },
        { headerName: "Lớp học phần", field: "LopHocPhan", editable: true, width: 250, filter: true },
        { headerName: "Khoa", field: "Khoa", editable: true, width: 100, filter: true },
        { headerName: "Giảng viên theo TKB", field: "GiaoVien", editable: true, width: 150, filter: true },
        { headerName: "Ngày bắt đầu", field: "NgayBatDau", editable: false, width: 110, valueFormatter: (p) => p.value ? p.value.split('T')[0] : '' },
        { headerName: "Ngày kết thúc", field: "NgayKetThuc", editable: false, width: 110, valueFormatter: (p) => p.value ? p.value.split('T')[0] : '' },
        { headerName: "LL", field: "LL", editable: true, width: 50, type: 'numericColumn' },
        // { headerName: "Số SV", field: "SoSinhVien", editable: false, width: 70, type: 'numericColumn' }, // Tạm comment
        // { headerName: "HS lớp đông", field: "HeSoLopDong", editable: false, width: 100, type: 'numericColumn' }, // Tạm comment
        // { headerName: "HS ngoài giờ", field: "HeSoT7CN", editable: false, width: 90, type: 'numericColumn' }, // Tạm comment
        { headerName: "QC", field: "QuyChuan", editable: true, width: 70, type: 'numericColumn' },
        {
          headerName: "Hệ đào tạo",
          field: "he_dao_tao",
          editable: false,
          width: 150,
          filter: true,
          valueFormatter: (params) => heDaoTaoMap[params.value] || params.value || "",
        },
        // Các cột ẩn hoặc đặc thù của riêng màn Core Info được để phía sau cùng
        // { headerName: "Số TC", field: "SoTinChi", editable: true, width: 80, type: 'numericColumn' }, // Tạm comment
        { headerName: "Tên lớp", field: "TenLop", editable: true, width: 150, filter: true }, // Đặc thù Core Info
        { headerName: "Mã học phần", field: "MaHocPhan", hide: true }, 
        { headerName: "ID", field: "ID", hide: true },
        { headerName: "Năm học", field: "NamHoc", hide: true },
        { headerName: "Version", field: "version", hide: true },
        {
          headerName: "Thao tác",
          field: "actions",
          filter: false,
          editable: false,
          width: 120,
          cellRenderer: (params) => {
            const id = params.data.ID; // Lấy ID từ dữ liệu (Quy chuẩn ID)
            const stt = params.node.rowIndex + 1; // Lấy STT của dòng
            return `<button onclick="deleteRow('${id}', ${stt})">Xóa</button>`;
          }
        }
      ];

      // Lấy từ localStorage nếu đã có
      const storedKhoa = JSON.parse(localStorage.getItem('KhoaList')) || [];
      const khoaArray = storedKhoa.map(item => item.MaPhongBan);

      const khoaCol = columnDefs.find(col => col.field === 'Khoa');
      if (khoaCol && khoaArray.length > 0) {
        khoaCol.cellEditor = 'agSelectCellEditor';
        khoaCol.cellEditorParams = { values: khoaArray };
      }

      // Gắn combobox cho cột Hệ đào tạo
      const heDaoTaoCol = columnDefs.find(col => col.field === 'he_dao_tao');
      if (heDaoTaoCol) {
        heDaoTaoCol.cellEditor = 'agSelectCellEditor';
        heDaoTaoCol.cellEditorParams = {
          values: heDaoTaoList.map(item => item.id),
        };
      }
      gridOptions = {
        columnDefs: columnDefs,
        rowData: [],
        defaultColDef: {
          resizable: true,
          sortable: true,
          filter: false,
          editable: false,
          headerClass: "custom-header",
          cellStyle: {
            fontSize: "14px", 
            whiteSpace: "normal", 
            wordWrap: "break-word", 
            textAlign: "center"
          }
        },
        rowHeight: 50,
        stopEditingWhenCellsLoseFocus: true,
        singleClickEdit: true,
        enterMovesDownAfterEdit: true,
        suppressClickEdit: false,
        overlayNoRowsTemplate: '<span style="padding: 10px;">Không có dữ liệu</span>',
        onGridReady: (params) => {
          gridApi = params.api;
          params.api.sizeColumnsToFit();
        },
        // Bắt sự kiện auto-save
        onCellValueChanged: async function (params) {
          const updatedField = params.colDef.field;
          const newValue = params.newValue;
          const oldValue = params.oldValue;

          if (newValue === oldValue || updatedField === 'version') return; 

          const data = params.data;
          
          if (['SoTinChi', 'LL', 'QuyChuan'].includes(updatedField) && isNaN(Number(newValue))) {
             Toastify({ text: "Giá trị phải là số hợp lệ!", backgroundColor: "#f44336" }).showToast();
             params.data[updatedField] = oldValue;
             params.api.refreshCells({ rowNodes: [params.node], force: true });
             return;
          }

          try {
            // Backend expects { records: [{ id, LopHocPhan, TenLop, SoTinChi, GiaoVien, Khoa, LL, QuyChuan, version }] }
            const payload = {
              records: [{
                id: data.ID,
                LopHocPhan: updatedField === 'LopHocPhan' ? newValue : data.LopHocPhan,
                TenLop: updatedField === 'TenLop' ? newValue : data.TenLop,
                SoTinChi: updatedField === 'SoTinChi' ? newValue : data.SoTinChi,
                GiaoVien: updatedField === 'GiaoVien' ? newValue : data.GiaoVien,
                Khoa: updatedField === 'Khoa' ? newValue : data.Khoa,
                LL: updatedField === 'LL' ? newValue : data.LL,
                QuyChuan: updatedField === 'QuyChuan' ? newValue : data.QuyChuan,
                version: data.version || 0
              }]
            };

            const response = await fetch('/api/v1/admin/moi-giang/core-info', {
              method: 'PUT',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(payload)
            });

            const result = await response.json();

            if (response.ok) {
              Toastify({ text: "✅ Cập nhật thành công", backgroundColor: "#4CAF50" }).showToast();
              if (result.updated && result.updated.length > 0) {
                 params.data['version'] = result.updated[0].version;
                 params.api.refreshCells({ rowNodes: [params.node], force: true });
              }
            } else if (response.status === 409) {
              Swal.fire({
                title: 'Dữ liệu không đồng bộ!',
                text: 'Dữ liệu này đã được sửa bởi phiên khác. Vui lòng tải lại.',
                icon: 'warning'
              });
              params.data[updatedField] = oldValue;
              params.api.refreshCells({ rowNodes: [params.node], force: true });
            } else if (response.status === 401) {
              handleApiError(result, response.status);
              params.data[updatedField] = oldValue;
              params.api.refreshCells({ rowNodes: [params.node], force: true });
            } else if (response.status === 403) {
              handleApiError(result, response.status);
              params.data[updatedField] = oldValue;
              params.api.refreshCells({ rowNodes: [params.node], force: true });
            } else {
              handleApiError(result, response.status, 'Auto-save');
              params.data[updatedField] = oldValue;
              params.api.refreshCells({ rowNodes: [params.node], force: true });
            }
          } catch (error) {
            console.error('[Admin Mời Giảng] Lỗi mạng hoặc không thể kết nối:', error);
            showToast('error', 'Lỗi mạng — không thể kết nối đến server.');
            params.data[updatedField] = oldValue;
            params.api.refreshCells({ rowNodes: [params.node], force: true });
          }
        }
      };

      const gridDiv = document.getElementById('myGrid');
      if (typeof agGrid.createGrid === 'function') {
        gridApi = agGrid.createGrid(gridDiv, gridOptions);
      } else {
        new agGrid.Grid(gridDiv, gridOptions);
        gridApi = gridOptions.api;
      }
    });

    // ─── Utilities ───────────────────────────────────────────────────────────

    /**
     * Hiển thị Toastify toast với màu sắc phù hợp.
     * @param {'success'|'error'|'info'} type
     * @param {string} text
     */
    function showToast(type, text) {
      const colors = { success: '#4CAF50', error: '#f44336', info: '#2196F3' };
      Toastify({
        text,
        duration: 3000,
        gravity: 'top',
        position: 'right',
        backgroundColor: colors[type] || '#333',
      }).showToast();
    }

    /**
     * Xử lý lỗi HTTP trả về từ API theo chuẩn Enterprise.
     * Luôn hiển thị thông báo UI rõ ràng thay vì nuốt lỗi.
     *
     * @param {object} result  - JSON body phản hồi từ backend
     * @param {number} status  - HTTP status code
     * @param {string} [context] - Ngữ cảnh thêm để log
     */
    function handleApiError(result, status, context = '') {
      const msg = result?.message || 'Đã xảy ra lỗi không xác định.';
      const errorCode = result?.errorCode || '';
      const logPrefix = context ? `[${context}]` : '[API Error]';

      console.error(`${logPrefix} HTTP ${status}`, errorCode, msg, result);

      if (status === 401) {
        Swal.fire({
          icon: 'warning',
          title: 'Phiên đăng nhập hết hạn',
          text: msg,
          confirmButtonText: 'Đăng nhập lại',
        }).then(() => { window.location.href = '/'; });
        return;
      }

      if (status === 403) {
        Swal.fire({
          icon: 'error',
          title: 'Không có quyền truy cập',
          text: msg,
        });
        return;
      }

      if (status === 409) {
        Swal.fire({
          icon: 'warning',
          title: 'Dữ liệu không đồng bộ',
          text: 'Bản ghi này vừa được chỉnh sửa bởi phiên khác. Vui lòng tải lại trang.',
          confirmButtonText: 'Tải lại',
        }).then(() => { window.location.reload(); });
        return;
      }

      if (status >= 500) {
        Swal.fire({
          icon: 'error',
          title: 'Lỗi hệ thống',
          text: msg + (errorCode ? ` (${errorCode})` : ''),
        });
        return;
      }

      // 400 và các lỗi khác
      showToast('error', `❌ ${msg}`);
    }

    // ─── Helper Functions (copy y nguyên từ TKB) ──────────────────────────────────────────────

    /**
     * T\u1ea3i \u0110\u1ee3t, K\u1ef3, N\u0103m h\u1ecdc t\u1eeb API /getNamHoc
     * Copy y nguy\u00ean l\u1ed9 tr\u00ecnh t\u1eeb tkb.thoiKhoaBieuChinhThuc.ejs
     * D\u00f9ng ID mg-* \u0111\u1ec3 tr\u00e1nh xung \u0111\u1ed9t v\u1edbi adminHeader.ejs (v\u1ed1n c\u00f3 id="NamHoc", id="HeDaoTao")
     */
    $(document).ready(function () {
      $('#mg-nam-hoc option[value=""]').remove();
      $('#mg-ki option[value=""]').remove();
      $('#mg-dot option[value=""]').remove();

      $.ajax({
        url: '/getNamHoc',
        method: 'GET',
        success: function (response) {
          if (response.success) {
            response.NamHoc.forEach(function (item) {
              $('#mg-nam-hoc').append(`<option value="${item.NamHoc}">${item.NamHoc}</option>`);
            });

            // \u2705 T\u1ef1 \u0111\u1ed9ng ch\u1ecdn n\u0103m h\u1ecdc \u0111ang ho\u1ea1t \u0111\u1ed9ng (trangthai = 1 - hi\u1ec3n th\u1ecb \u0111\u1ea7u ti\u00ean)
            if (response.NamHoc.length > 0) {
              $('#mg-nam-hoc').val(response.NamHoc[0].NamHoc);
            }

            response.Ki.forEach(function (item) {
              $('#mg-ki').append(`<option value="${item.value}">${item.Ki}</option>`);
            });
            response.Dot.forEach(function (item) {
              $('#mg-dot').append(`<option value="${item.value}">${item.Dot}</option>`);
            });
          } else {
            console.error('Kh\u00f4ng l\u1ea5y \u0111\u01b0\u1ee3c d\u1eef li\u1ec7u n\u0103m h\u1ecdc:', response.message);
          }
        },
        error: function (error) {
          console.error('L\u1ed7i khi l\u1ea5y d\u1eef li\u1ec7u n\u0103m h\u1ecdc:', error);
        },
      });
    });

    /**
     * T\u1ea3i danh s\u00e1ch Khoa t\u1eeb API /api/TKB/getKhoaList
     * Copy y nguy\u00ean l\u1ed9 tr\u00ecnh t\u1eeb tkb.thoiKhoaBieuChinhThuc.ejs
     */
    $(document).ready(function () {
      $('#mg-khoa option[value=""]').remove();

      $.ajax({
        url: '/api/TKB/getKhoaList',
        method: 'GET',
        success: function (response) {
          if (response.success) {
            $('#mg-khoa').prepend('<option value="ALL">T\u1ea5t c\u1ea3 khoa</option>');
            const khoaItems = [];
            response.MaPhongBan.forEach(function (item) {
              $('#mg-khoa').append(`<option value="${item.MaPhongBan}">${item.MaPhongBan}</option>`);
              khoaItems.push(item.MaPhongBan);
            });
            $('#mg-khoa').append('<option value="Khac">Kh\u00e1c</option>');
            khoaItems.push('Khac');

            if (!$('#mg-khoa option:selected').length) {
              $('#mg-khoa').prepend('<option value="">Chọn Khoa</option>');
            }

            // Lưu vào localStorage giống hệt TKB
            localStorage.setItem("KhoaList", JSON.stringify(response.MaPhongBan));

            // Cập nhật cellEditorParams của cột Khoa sau khi có data
            if (typeof gridOptions !== 'undefined' && gridOptions && gridOptions.columnDefs) {
              const khoaColDef = gridOptions.columnDefs.find(function(c) { return c.field === 'Khoa'; });
              if (khoaColDef) {
                khoaColDef.editable = true;
                khoaColDef.cellEditor = 'agSelectCellEditor';
                khoaColDef.cellEditorParams = { values: khoaItems };
                if (gridApi) {
                  if (gridApi.setColumnDefs) {
                    gridApi.setColumnDefs(gridOptions.columnDefs);
                  } else if (gridApi.setGridOption) {
                    gridApi.setGridOption('columnDefs', gridOptions.columnDefs);
                  }
                }
              }
            }
          } else {
            console.error('Kh\u00f4ng l\u1ea5y \u0111\u01b0\u1ee3c danh s\u00e1ch khoa:', response.message);
          }
        },
        error: function (error) {
          console.error('L\u1ed7i khi l\u1ea5y danh s\u00e1ch khoa:', error);
        },
      });
    });

    /**
     * T\u1ea3i danh s\u00e1ch H\u1ec7 \u0111\u00e0o t\u1ea1o t\u1eeb API /api/gvm/v1/he-moi-giang
     * Copy y nguy\u00ean l\u1ed9 tr\u00ecnh t\u1eeb tkb.thoiKhoaBieuChinhThuc.ejs
     */
    async function loadHeDaoTaoFromAPI() {
      try {
        const response = await fetch('/api/gvm/v1/he-moi-giang');
        if (!response.ok) throw new Error('Failed to fetch');
        const result = await response.json();

        if (result.success && result.data) {
          const heDaoTaoSelect = document.getElementById('mg-he-dao-tao');
          if (heDaoTaoSelect) {
            heDaoTaoSelect.innerHTML = '<option value="ALL">T\u1ea5t c\u1ea3 h\u1ec7 \u0111\u00e0o t\u1ea1o</option>';
            result.data.forEach(item => {
              const opt = document.createElement('option');
              opt.value = item.id;
              opt.textContent = item.he_dao_tao;
              heDaoTaoSelect.appendChild(opt);
            });
          }
        }
      } catch (error) {
        console.error('L\u1ed7i khi load h\u1ec7 \u0111\u00e0o t\u1ea1o:', error);
      }
    }

    async function loadTableData() {
      const dotValue = document.getElementById('mg-dot').value;
      const kiValue = document.getElementById('mg-ki').value;
      const namValue = document.getElementById('mg-nam-hoc').value;
      const khoaValue = document.getElementById('mg-khoa').value;
      const heDaoTaoValue = document.getElementById('mg-he-dao-tao').value;

      // Build heDaoTaoMap từ localStorage — giống hệt TKB
      heDaoTaoList = JSON.parse(localStorage.getItem('HE_DAO_TAO_CACHE')) || [];
      heDaoTaoMap = {};
      heDaoTaoList.forEach(item => {
        heDaoTaoMap[item.id] = item.tenHe;
      });

      if (!dotValue || !kiValue || !namValue) {
        Toastify({ text: "Vui l\u00f2ng ch\u1ecdn \u0110\u1ee3t, K\u1ef3, N\u0103m h\u1ecdc", backgroundColor: "#f44336" }).showToast();
        return;
      }

      const requestData = {
        Khoa: khoaValue,
        Dot: dotValue,
        Ki: kiValue,
        Nam: namValue,
        HeDaoTao: heDaoTaoValue,
      };

      try {
        const response = await fetch('/api/v1/admin/moi-giang/core-info/data', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(requestData),
        });

        const data = await response.json().catch(() => ({}));

        if (!response.ok) {
          handleApiError(data, response.status, 'loadTableData');
          if (gridApi.setGridOption) { gridApi.setGridOption('rowData', []); } else { gridApi.setRowData([]); }
          return;
        }

        globalData = data.results || [];
        if (gridApi.setGridOption) { gridApi.setGridOption('rowData', globalData); } else { gridApi.setRowData(globalData); }
        if (globalData.length === 0) {
          showToast('info', 'Không có dữ liệu cho bộ lọc đã chọn.');
        }
      } catch (error) {
        console.error('[loadTableData] Lỗi mạng:', error);
        Swal.fire('Lỗi kết nối', 'Không thể kết nối đến server. Vui lòng thử lại.', 'error');
      }
    }
    // Xử lý Xóa từng dòng trên lưới
    async function deleteRow(id, stt) {
      Swal.fire({
        title: "Xác nhận xóa?",
        html: `Bạn có chắc chắn muốn xóa dòng <b>${stt}</b> không?`,
        icon: "warning",
        showCancelButton: true,
        confirmButtonColor: "#d33",
        cancelButtonColor: "#3085d6",
        confirmButtonText: "Xóa",
        cancelButtonText: "Hủy",
        width: "auto",
        padding: "20px",
      }).then(async (result) => {
        if (result.isConfirmed) {
          try {
            const response = await fetch(`/api/v1/admin/moi-giang/core-info/delete-row?id=${id}`, {
              method: "DELETE",
            });
            
            if (response.ok) {
              const data = await response.json();
              
              // Xóa dòng khỏi AG Grid
              const rowNode = gridApi.getRowNode(id);
              if (rowNode) {
                gridApi.applyTransaction({ remove: [rowNode.data] });
              }
              
              Swal.fire({
                title: "Đã xóa!",
                text: data.message || "Dòng dữ liệu đã được xóa.",
                icon: "success",
                confirmButtonText: "OK",
                width: "auto",
                padding: "20px",
              });
            } else {
              Swal.fire({
                title: "Lỗi",
                text: "Có lỗi xảy ra khi xóa dữ liệu.",
                icon: "error",
                confirmButtonText: "OK",
                width: "auto",
                padding: "20px",
              });
            }
          } catch (error) {
            console.error("Lỗi khi gọi API xóa:", error);
            Swal.fire({
              title: "Lỗi",
              text: "Không thể kết nối đến máy chủ.",
              icon: "error",
              confirmButtonText: "OK",
              width: "auto",
              padding: "20px",
            });
          }
        }
      });
    }
  </script>
</body>
