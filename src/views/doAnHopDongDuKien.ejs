    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const role = localStorage.getItem("userRole");

        // Ẩn button ngay khi trang được tải
        const actionButton = document.getElementById("changeMessage");
        //Ẩn site thêm thông báo
        if (role === "<%= APP_ROLES.troLy_phong %>" || role === "<%= APP_ROLES.lanhDao_phong %>") {
          actionButton.style.display = "";
        } else {
          actionButton.style.display = "none";
        }

        loadHeDoAnToSelect();
      });

      async function loadHeDoAnToSelect() {
        try {
          const res = await fetch('/api/gvm/v1/he-do-an');
          const json = await res.json();

          if (!json.success) {
            console.error('API lỗi');
            return;
          }

          const select = document.getElementById('he_dao_tao');
          if (!select) return;

          // clear option cũ (nếu cần reload)
          select.innerHTML = '';

          json.data.forEach(item => {
            const option = document.createElement('option');
            option.value = item.id;
            option.textContent = item.he_dao_tao;
            select.appendChild(option);
          });

        } catch (err) {
          console.error('Lỗi load hệ đồ án:', err);
        }
      }
    </script>
