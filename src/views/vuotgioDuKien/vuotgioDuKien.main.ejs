<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vượt Giờ Dự Kiến</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        /* ===== DESIGN TOKENS ===== */
        :root {
            --primary: #6366f1;
            --primary-light: #818cf8;
            --primary-dark: #4f46e5;
            --primary-glow: rgba(99, 102, 241, 0.25);
            --accent: #06b6d4;
            --accent-light: #22d3ee;
            --surface: #ffffff;
            --surface-glass: rgba(255, 255, 255, 0.72);
            --background: #f0f2f8;
            --bg-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --bg-subtle: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            --text-main: #1e1b4b;
            --text-secondary: #4b5563;
            --text-muted: #9ca3af;
            --border: rgba(99, 102, 241, 0.12);
            --border-strong: rgba(99, 102, 241, 0.25);
            --danger: #ef4444;
            --success: #10b981;
            --warning: #f59e0b;
            --radius-sm: 8px;
            --radius-md: 14px;
            --radius-lg: 20px;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
            --shadow-md: 0 4px 16px rgba(99, 102, 241, 0.10), 0 1px 4px rgba(0,0,0,0.06);
            --shadow-lg: 0 12px 40px rgba(99, 102, 241, 0.15), 0 4px 12px rgba(0,0,0,0.06);
            --transition-fast: 0.18s cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* ===== BASE ===== */
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--background);
            color: var(--text-main);
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ===== MAIN CONTAINER ===== */
        .container-custom {
            background: var(--surface-glass);
            backdrop-filter: blur(16px) saturate(180%);
            -webkit-backdrop-filter: blur(16px) saturate(180%);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-lg);
            padding: 32px;
            margin-top: 28px !important;
            margin-bottom: 40px;
            animation: fadeSlideIn 0.5s ease-out;
        }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(18px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ===== HEADER ===== */
        .header-title {
            font-size: 26px;
            font-weight: 800;
            letter-spacing: -0.5px;
            margin-bottom: 28px;
            padding-bottom: 16px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            border-bottom: none;
            position: relative;
        }
        .header-title::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 72px;
            height: 3px;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--primary), var(--accent));
        }

        /* ===== FILTER SECTION ===== */
        .filter-section {
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            margin-bottom: 28px;
            background: linear-gradient(135deg, rgba(99,102,241,0.06) 0%, rgba(6,182,212,0.06) 100%);
            padding: 20px 24px;
            border-radius: var(--radius-md);
            align-items: flex-end;
            border: 1px solid var(--border);
            transition: box-shadow var(--transition-smooth);
        }
        .filter-section:hover {
            box-shadow: 0 4px 20px rgba(99, 102, 241, 0.08);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 6px;
            min-width: 155px;
        }
        .form-group label {
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .filter-section .form-control {
            padding: 9px 14px;
            border: 1.5px solid rgba(99, 102, 241, 0.18);
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-family: inherit;
            color: var(--text-main);
            background: var(--surface);
            outline: none;
            transition: all var(--transition-fast);
            box-shadow: var(--shadow-sm);
        }
        .filter-section .form-control:focus {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px var(--primary-glow);
        }

        /* ===== BUTTON ===== */
        .filter-section .btn {
            padding: 9px 24px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: 14px;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all var(--transition-fast);
            height: auto;
            box-shadow: 0 2px 8px rgba(99, 102, 241, 0.30);
            position: relative;
            overflow: hidden;
        }
        .filter-section .btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, transparent 0%, rgba(255,255,255,0.15) 100%);
            opacity: 0;
            transition: opacity var(--transition-fast);
        }
        .filter-section .btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(99, 102, 241, 0.40);
        }
        .filter-section .btn:hover::before {
            opacity: 1;
        }
        .filter-section .btn:active {
            transform: translateY(0);
        }

        /* ===== TABS ===== */
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 24px;
            overflow-x: auto;
            padding: 6px;
            background: rgba(99, 102, 241, 0.05);
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            border-bottom: 1px solid var(--border);
            scrollbar-width: thin;
        }
        .tabs::-webkit-scrollbar {
            height: 4px;
        }
        .tabs::-webkit-scrollbar-thumb {
            background: var(--primary-light);
            border-radius: 4px;
        }

        .tab-btn {
            padding: 10px 20px;
            background: transparent;
            border: none;
            border-bottom: none;
            border-radius: var(--radius-sm);
            font-size: 13.5px;
            font-weight: 600;
            font-family: inherit;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all var(--transition-fast);
            white-space: nowrap;
            position: relative;
        }
        .tab-btn:hover {
            color: var(--primary);
            background: rgba(99, 102, 241, 0.08);
        }
        .tab-btn.tab-active {
            color: #fff;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            box-shadow: 0 2px 10px rgba(99, 102, 241, 0.30);
            border-bottom-color: transparent;
        }

        /* ===== TAB CONTENT ===== */
        .tab-content {
            display: none;
        }
        .tab-content.tab-active {
            display: block;
            animation: tabFadeIn 0.35s ease-out;
        }
        @keyframes tabFadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ===== TABLE ===== */
        .table-responsive {
            overflow-x: auto;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
        }

        .table {
            margin-bottom: 0;
            font-size: 13.5px;
        }
        .table thead {
            position: sticky;
            top: 0;
            z-index: 2;
        }
        .table thead th {
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%) !important;
            color: #fff !important;
            font-weight: 600;
            font-size: 12.5px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            padding: 14px 12px;
            border: none !important;
            border-bottom: none !important;
            white-space: nowrap;
        }
        .table thead th:first-child {
            border-top-left-radius: var(--radius-md);
        }
        .table thead th:last-child {
            border-top-right-radius: var(--radius-md);
        }

        .table tbody tr {
            transition: all var(--transition-fast);
        }
        .table tbody tr:nth-child(even) {
            background: rgba(99, 102, 241, 0.025);
        }
        .table tbody tr:hover {
            background: rgba(99, 102, 241, 0.07) !important;
        }
        .table tbody td {
            padding: 11px 12px;
            vertical-align: middle;
            border-color: rgba(99, 102, 241, 0.08);
            color: var(--text-main);
        }
        .table tbody td strong {
            color: var(--primary-dark);
            font-weight: 700;
        }

        /* ===== EMPTY STATE ===== */
        .empty-state {
            text-align: center;
            padding: 56px 24px;
            color: var(--text-muted);
            font-size: 15px;
            font-style: italic;
        }

        /* ===== BADGE ===== */
        .badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            background: rgba(99, 102, 241, 0.10);
            color: var(--primary);
        }
        .badge.warning {
            background: rgba(245, 158, 11, 0.12);
            color: #b45309;
        }

        /* ===== SEARCH BOX ===== */
        .search-box {
            display: flex;
            align-items: center;
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 28px;
            padding: 6px 18px;
            max-width: 260px;
            flex: 1;
            transition: all var(--transition-fast);
            box-shadow: var(--shadow-sm);
        }
        .search-box:focus-within {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px var(--primary-glow);
        }
        .search-box i {
            color: var(--text-muted);
            margin-right: 10px;
            font-size: 13px;
            transition: color var(--transition-fast);
        }
        .search-box:focus-within i {
            color: var(--primary);
        }
        .search-box input {
            border: none;
            background: transparent;
            outline: none;
            width: 100%;
            font-size: 13.5px;
            font-family: inherit;
            padding: 5px 0;
            color: var(--text-main);
        }
        .search-box input::placeholder {
            color: var(--text-muted);
            font-weight: 400;
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 768px) {
            .container-custom {
                padding: 18px;
                border-radius: var(--radius-md);
            }
            .filter-section {
                padding: 14px 16px;
            }
            .header-title {
                font-size: 22px;
            }
            .tab-btn {
                padding: 8px 14px;
                font-size: 12.5px;
            }
        }

        /* ===== SCROLLBAR ===== */
        .table-responsive::-webkit-scrollbar {
            height: 6px;
        }
        .table-responsive::-webkit-scrollbar-track {
            background: rgba(99, 102, 241, 0.04);
            border-radius: 4px;
        }
        .table-responsive::-webkit-scrollbar-thumb {
            background: rgba(99, 102, 241, 0.20);
            border-radius: 4px;
        }
        .table-responsive::-webkit-scrollbar-thumb:hover {
            background: rgba(99, 102, 241, 0.35);
        }

        /* ===== LOADING SHIMMER ===== */
        @keyframes shimmer {
            0%   { background-position: -200% 0; }
            100% { background-position: 200% 0; }
        }
    </style>
</head>
<body>
    <%- include('../header') %>
    <div class="container container-custom" style="margin-top: 20px;">
        <h1 class="header-title">Quản lý Vượt Giờ Dự Kiến</h1>

        <!-- Filters -->
        <div class="filter-section">
            <div class="form-group">
                <label>Năm học</label>
                <select id="filterNamHoc" class="form-control">
                    <!-- Options populated by JS -->
                </select>
            </div>
            <div class="form-group">
                <label>Kỳ học</label>
                <select id="filterKiHoc" class="form-control">
                    <option value="ALL">Tất cả</option>
                    <option value="1">Kỳ 1</option>
                    <option value="2">Kỳ 2</option>
                </select>
            </div>
            <div class="form-group">
                <label>Đợt</label>
                <select id="filterDot" class="form-control">
                    <option value="ALL">Tất cả</option>
                    <option value="1">Đợt 1</option>
                    <option value="2">Đợt 2</option>
                </select>
            </div>
            <div class="form-group">
                <label>Khoa</label>
                <select id="filterKhoa" class="form-control">
                    <option value="ALL">Tất cả</option>
                    <!-- Options populated by JS -->
                </select>
            </div>
            <button class="btn" onclick="loadCurrentTab()">Xem dữ liệu</button>
        </div>

        <!-- Tabs Navigation -->
        <div class="tabs">
            <button class="tab-btn tab-active" onclick="switchTab('giangDayQC', this)">1. Giảng dạy quy chuẩn</button>
            <button class="tab-btn" onclick="switchTab('datn', this)">2. Hướng dẫn ĐATN</button>
            <button class="tab-btn" onclick="switchTab('lopNgoaiQC', this)">3. Lớp ngoài QC</button>
            <button class="tab-btn" onclick="switchTab('thamQuan', this)">4. Hướng dẫn tham quan</button>
            <button class="tab-btn" onclick="switchTab('kthp', this)">5. KTHP</button>
            <button class="tab-btn" onclick="switchTab('nckh', this)">6. NCKH Dự kiến</button>
        </div>

        <!-- Tab Contents -->
        
        <!-- 1. Giảng dạy QC -->
        <div id="giangDayQC" class="tab-content tab-active">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="giangVien" placeholder="Tìm giảng viên..." oninput="applyTableFilter('giangDayQC')">
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="tenHocPhan" placeholder="Tìm môn học..." oninput="applyTableFilter('giangDayQC')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Giảng viên</th>
                            <th>Môn học</th>
                            <th>Tên lớp</th>
                            <th>Số tín chỉ</th>
                            <th>Đợt</th>
                            <th>Kỳ</th>
                            <th>Năm học</th>
                            <th>Số tiết QC</th>
                            <th>Tổng số tiết</th>
                            <th>Khoa</th>
                            <th>Hệ đào tạo</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-giangDayQC">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 2. Hướng dẫn ĐATN -->
        <div id="datn" class="tab-content">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="GiangVien_HienThi" placeholder="Tìm giảng viên..." oninput="applyTableFilter('datn')">
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="MaPhongBan|Khoa" placeholder="Tìm khoa..." oninput="applyTableFilter('datn')">
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="SinhVien" placeholder="Tìm sinh viên..." oninput="applyTableFilter('datn')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50px;">STT</th>
                            <th style="width: 180px;">Giảng viên</th>
                            <th style="width: 100px;">Khoa</th>
                            <th style="width: 180px;">Sinh viên</th>
                            <th style="width: 80px;">Khóa</th>
                            <th style="width: 250px;">Tên đề tài</th>
                            <th style="width: 70px;">Số tiết</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-datn">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 3. Lớp Ngoài Quy Chuẩn -->
        <div id="lopNgoaiQC" class="tab-content">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="GiangVien|GiaoVienGiangDay" placeholder="Tìm giảng viên..." oninput="applyTableFilter('lopNgoaiQC')">
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="LopHocPhan" placeholder="Tìm môn học..." oninput="applyTableFilter('lopNgoaiQC')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Giảng viên</th>
                            <th>Môn học</th>
                            <th>Tên lớp</th>
                            <th>Số tín chỉ</th>
                            <th>Đợt</th>
                            <th>Kỳ</th>
                            <th>Khoa</th>
                            <th>Số tiết QC</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-lnqc">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 4. Hướng Dẫn Tham Quan -->
        <div id="thamQuan" class="tab-content">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="HoTen" placeholder="Tìm giảng viên..." oninput="applyTableFilter('thamQuan')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Giảng viên</th>
                            <th>Khoa</th>
                            <th>Ngành học</th>
                            <th>Đợt</th>
                            <th>Kỳ</th>
                            <th>Mô tả hoạt động</th>
                            <th>Theo QĐ</th>
                            <th>Số ngày</th>
                            <th>Số tiết quy đổi</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-thamquan">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 5. KTHP -->
        <div id="kthp" class="tab-content">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="giangvien|giang_vien" placeholder="Tìm giảng viên..." oninput="applyTableFilter('kthp')">
                </div>
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="tenhocphan|ten_hoc_phan" placeholder="Tìm học phần..." oninput="applyTableFilter('kthp')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Giảng viên</th>
                            <th>Khoa</th>
                            <th>Kỳ</th>
                            <th>Hình thức</th>
                            <th>Tên học phần</th>
                            <th>Lớp học phần</th>
                            <th>Đối tượng</th>
                            <th>Tổng số bài</th>
                            <th>Số tiết QC</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-kthp">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- 6. NCKH Dự Kiến -->
        <div id="nckh" class="tab-content">
            <div class="d-flex gap-3 mb-3">
                <div class="search-box">
                    <i class="fas fa-search"></i>
                    <input type="text" class="column-filter" data-field="tenNhanVien|tenGV|TenGiangVien" placeholder="Tìm giảng viên..." oninput="applyTableFilter('nckh')">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover text-center" style="width: 100%">
                    <thead class="table-light">
                        <tr>
                            <th>STT</th>
                            <th>Giảng viên</th>
                            <th>Chức danh</th>
                            <th>Khoa/Phòng ban</th>
                            <th>Tổng giờ NCKH</th>
                        </tr>
                    </thead>
                    <tbody id="tbody-nckh">
                        <!-- Data rows -->
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Init data
        document.addEventListener('DOMContentLoaded', () => {
            initFilters();
            // Not loading tab automatically until year is selected
        });

        // Filter Logic
        function initFilters() {
            // Generate Academic Years
            const yearSelect = document.getElementById('filterNamHoc');
            const currentYear = new Date().getFullYear();
            for(let i = currentYear - 3; i <= currentYear + 1; i++) {
                const yearStr = `${i} - ${i+1}`;
                const option = document.createElement('option');
                option.value = yearStr;
                option.textContent = yearStr;
                if(i === currentYear - 1) option.selected = true; // default prev year
                yearSelect.appendChild(option);
            }

            // Fetch global config for Khoa
            fetch('/api/get-khoa-list')
                .then(res => res.json())
                .then(data => {
                    const khoaSelect = document.getElementById('filterKhoa');
                    data.forEach(d => {
                        const opt = document.createElement('option');
                        opt.value = d.MaPhongBan;
                        // Use TenPhongBan if available, fallback to MaPhongBan
                        opt.textContent = d.TenPhongBan ? `${d.TenPhongBan} (${d.MaPhongBan})` : d.MaPhongBan;
                        khoaSelect.appendChild(opt);
                    });
                })
                .catch(err => console.log('Err fetching Khoa:', err));
            
            // Initial load
            setTimeout(loadCurrentTab, 500);
        }

        function getFilterValues() {
            return {
                NamHoc: document.getElementById('filterNamHoc').value,
                KiHoc: document.getElementById('filterKiHoc').value,
                Dot: document.getElementById('filterDot').value,
                Khoa: document.getElementById('filterKhoa').value,
            };
        }

        // Tab Logic
        let currentTabId = 'giangDayQC';

        function switchTab(tabId, btnElement) {
            // Update buttons
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('tab-active'));
            btnElement.classList.add('tab-active');

            // Update content
            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('tab-active'));
            document.getElementById(tabId).classList.add('tab-active');

            currentTabId = tabId;
            loadCurrentTab();
        }

        function loadCurrentTab() {
            const filters = getFilterValues();
            console.log("Filters đang gọi:", filters);
            console.log("Current Tab:", currentTabId);
            
            const qs = new URLSearchParams(filters).toString();

            // Xóa nội dung filter input khi chuyển tab hoặc reload tab
            const tabContainer = document.getElementById(currentTabId);
            if (tabContainer) {
                tabContainer.querySelectorAll('.column-filter').forEach(inp => inp.value = '');
            }

            if (currentTabId === 'giangDayQC') {
                fetchData(`/v2/vuotgio-du-kien/giang-day-qc?${qs}`, renderGiangDayQC, currentTabId);
            } else if (currentTabId === 'datn') {
                fetchData(`/v2/vuotgio-du-kien/datn?${qs}`, renderDATN, currentTabId);
            } else if (currentTabId === 'nckh') {
                // NCKH doesn't use Dot/KiHoc
                fetchData(`/v2/vuotgio-du-kien/nckh?NamHoc=${filters.NamHoc}&Khoa=${filters.Khoa}`, renderNCKH, currentTabId);
            } else if (currentTabId === 'lopNgoaiQC') {
                fetchData(`/v2/vuotgio-du-kien/lnqc?NamHoc=${filters.NamHoc}&Khoa=${filters.Khoa}`, renderLNQC, currentTabId);
            } else if (currentTabId === 'thamQuan') {
                fetchData(`/v2/vuotgio-du-kien/thamquan?${qs}`, renderThamQuan, currentTabId);
            } else if (currentTabId === 'kthp') {
                fetchData(`/v2/vuotgio-du-kien/kthp?NamHoc=${filters.NamHoc}&Khoa=${filters.Khoa}`, renderKTHP, currentTabId);
            } else {
                console.log("Tab hiện tại chưa được xử lý fetch:", currentTabId);
            }
        }

        let tabDataCache = {};
        const renderTabMap = {
            'giangDayQC': renderGiangDayQC,
            'datn': renderDATN,
            'lopNgoaiQC': renderLNQC,
            'thamQuan': renderThamQuan,
            'kthp': renderKTHP,
            'nckh': renderNCKH
        };

        async function fetchData(url, renderFn, tabId) {
            console.log("Đang fetch URL:", url);
            try {
                const res = await fetch(url);
                console.log("Status:", res.status);
                const data = await res.json();
                console.log("Dữ liệu nhận được:", data);
                tabDataCache[tabId] = data;
                renderFn(data);
            } catch (error) {
                console.error("Lỗi khi lấy dữ liệu:", error);
                alert("Không thể tải dữ liệu: " + error.message);
            }
        }

        function applyTableFilter(tabId) {
            const rawResponse = tabDataCache[tabId];
            if (!rawResponse) return;
            
            const tabContainer = document.getElementById(tabId);
            const inputs = tabContainer.querySelectorAll('.column-filter');
            const filters = {};
            inputs.forEach(inp => {
                const val = inp.value.trim().toLowerCase();
                if (val) {
                    filters[inp.getAttribute('data-field')] = val;
                }
            });

            if (Object.keys(filters).length === 0) {
                renderTabMap[tabId](rawResponse);
                return;
            }

            let originalData = rawResponse.data || rawResponse; 
            let filteredData = [];

            if (tabId === 'giangDayQC') {
                originalData.forEach(teacher => {
                    let tMatch = true;
                    if (filters['giangVien'] && !(teacher.giangVien || '').toLowerCase().includes(filters['giangVien'])) tMatch = false;
                    if (filters['tongSoTietKy'] && !(String(teacher.tongSoTietKy || '')).toLowerCase().includes(filters['tongSoTietKy'])) tMatch = false;
                    if (filters['khoa'] && !(teacher.khoa || '').toLowerCase().includes(filters['khoa'])) tMatch = false;

                    if (tMatch) {
                        const filteredCourses = teacher.courses.filter(course => {
                            for (let field in filters) {
                                if (['giangVien', 'tongSoTietKy', 'khoa'].includes(field)) continue;
                                const val = String(course[field] || '').toLowerCase();
                                if (!val.includes(filters[field])) return false;
                            }
                            return true;
                        });
                        
                        if (filteredCourses.length > 0) {
                            filteredData.push({
                                ...teacher,
                                courses: filteredCourses
                            });
                        }
                    }
                });
            } else {
                filteredData = originalData.filter(row => {
                    for (let field in filters) {
                        const fieldKeys = field.split('|');
                        let match = false;
                        for(let k of fieldKeys) {
                            const cellVal = String(row[k] || '').toLowerCase();
                            if (cellVal.includes(filters[field])) {
                                match = true;
                                break;
                            }
                        }
                        if (!match) return false;
                    }
                    return true;
                });
            }

            const fakeResponse = Array.isArray(rawResponse) ? filteredData : { ...rawResponse, data: filteredData };
            renderTabMap[tabId](fakeResponse);
        }

        // Render Functions
        function getHeDaoTaoLabel(id) {
            return id;
        }

        function renderGiangDayQC(response) {
            const data = response.data || [];
            const tbody = document.getElementById('tbody-giangDayQC');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="12" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            let stt = 1;
            
            data.forEach((teacher) => {
                const rowSpan = teacher.courses.length;
                if (!rowSpan) return;

                teacher.courses.forEach((course, index) => {
                    html += `<tr>`;

                    if (index === 0) {
                        html += `<td rowspan="${rowSpan}">${stt}</td>`;
                        html += `<td rowspan="${rowSpan}">${teacher.giangVien || ''}</td>`;
                    }

                    html += `<td>${course.tenHocPhan || ""}</td>`;
                    html += `<td>${course.lop || ""}</td>`;
                    html += `<td>${course.soTinChi ?? ""}</td>`;
                    html += `<td>${course.dot ?? ""}</td>`;
                    html += `<td>${course.kiHoc ?? ""}</td>`;
                    html += `<td>${course.namHoc ?? ""}</td>`;
                    html += `<td>${(Number(course.quyChuan) || 0).toFixed(2)}</td>`;

                    if (index === 0) {
                        html += `<td rowspan="${rowSpan}">${(Number(teacher.tongSoTietKy) || 0).toFixed(2)}</td>`;
                        html += `<td rowspan="${rowSpan}">${teacher.khoa || ""}</td>`;
                    }

                    html += `<td>${course.heDaoTao || ''}</td>`;
                    html += `</tr>`;
                });

                stt += 1;
            });
            tbody.innerHTML = html;
        }

        function renderDATN(data) {
            const tbody = document.getElementById('tbody-datn');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            let currentGVKey = "";
            let stt = 0;

            data.forEach((row, index) => {
                const gv = row.GiangVien_HienThi || "";
                const khoa = row.MaPhongBan || row.Khoa || "";
                const gvKey = `${khoa}_${gv}`;
                
                const isNewGV = gvKey !== currentGVKey;
                
                if (isNewGV) {
                    currentGVKey = gvKey;
                    stt++;
                    
                    let gvCount = 0;
                    for (let i = index; i < data.length; i++) {
                        const nextGv = data[i].GiangVien_HienThi || "";
                        const nextKhoa = data[i].MaPhongBan || data[i].Khoa || "";
                        if (`${nextKhoa}_${nextGv}` === gvKey) {
                            gvCount++;
                        } else {
                            break;
                        }
                    }
                    
                    html += `<tr>
                        <td rowspan="${gvCount}">${stt}</td>
                        <td rowspan="${gvCount}">${gv}</td>
                        <td rowspan="${gvCount}">${khoa}</td>
                        <td>${row.SinhVien || ""}</td>
                        <td>${row.KhoaSV || ""}</td>
                        <td>${row.TenDeTai || ""}</td>
                        <td>${row.SoTietQuyDoi || row.SoTiet || 0}</td>
                    </tr>`;
                } else {
                    html += `<tr>
                        <td>${row.SinhVien || ""}</td>
                        <td>${row.KhoaSV || ""}</td>
                        <td>${row.TenDeTai || ""}</td>
                        <td>${row.SoTietQuyDoi || row.SoTiet || 0}</td>
                    </tr>`;
                }
            });
            tbody.innerHTML = html;
        }

        function renderNCKH(data) {
            const tbody = document.getElementById('tbody-nckh');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            data.forEach((row, idx) => {
                html += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${row.tenNhanVien || row.tenGV || row.TenGiangVien || ''}</td>
                        <td>${row.chucDanh || ''}</td>
                        <td>${row.maPhongBan || row.lecturerKhoaName || row.khoa || ''}</td>
                        <td><strong>${row.tongSoTietGiangVien || row.tongGio || 0}</strong></td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderLNQC(response) {
            const data = response.data || [];
            const tbody = document.getElementById('tbody-lnqc');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="9" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            data.forEach((row, idx) => {
                html += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${row.GiangVien || row.GiaoVienGiangDay || ''}</td>
                        <td>${row.LopHocPhan || ''}</td>
                        <td>${row.TenLop || ''}</td>
                        <td>${row.SoTinChi || 0}</td>
                        <td>${row.Dot || ''}</td>
                        <td>${row.KiHoc || ''}</td>
                        <td>${row.Khoa || ''}</td>
                        <td><strong>${(Number(row.QuyChuan) || 0).toFixed(2)}</strong></td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderThamQuan(response) {
            const data = response.data || [];
            const tbody = document.getElementById('tbody-thamquan');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="10" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            data.forEach((row, idx) => {
                html += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${row.HoTen || ''}</td>
                        <td>${row.khoa || ''}</td>
                        <td>${row.nganh_hoc || ''}</td>
                        <td>${row.dot || ''}</td>
                        <td>${row.hoc_ky || ''}</td>
                        <td>${row.mo_ta_hoat_dong || ''}</td>
                        <td>${row.theo_qd || ''}</td>
                        <td>${row.so_ngay || 0}</td>
                        <td><strong>${(Number(row.so_tiet_quy_doi) || 0).toFixed(2)}</strong></td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function renderKTHP(response) {
            const data = response.data || [];
            const tbody = document.getElementById('tbody-kthp');
            if(!data || data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="10" class="empty-state">Không có dữ liệu</td></tr>`;
                return;
            }
            
            let html = '';
            data.forEach((row, idx) => {
                html += `
                    <tr>
                        <td>${idx + 1}</td>
                        <td>${row.giangvien || row.giang_vien || ''}</td>
                        <td>${row.khoa || ''}</td>
                        <td>${row.ki || row.hoc_ky || ''}</td>
                        <td>${row.hinhthuc || row.hinh_thuc || ''}</td>
                        <td>${row.tenhocphan || row.ten_hoc_phan || ''}</td>
                        <td>${row.lophocphan || row.lop_hoc_phan || ''}</td>
                        <td>${row.doituong || row.doi_tuong || ''}</td>
                        <td>${row.tongso || row.tong_so || 0}</td>
                        <td><strong>${(Number(row.sotietqc) || 0).toFixed(2)}</strong></td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }
    </script>
</body>
</html>
